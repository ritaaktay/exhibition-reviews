<!-- context variables are review = review document
    commentMap = review.ids mapped to arrays of comment documents -->
<div>
    <strong>Review</strong> 
    <br>
    <p> <%= review.content%> </p>
    <div>
    <% review.decodedImages.forEach(image => { %>
        <img height=200 src="<%=image%>"> 
    <% }) %>
    </div> <br>
    <span> <%= review.createdAt.toLocaleString('en-UK', {
                    timeStyle: "short",
                    dateStyle: "medium"})%> </span>
    <br><br>
    <strong>Comments</strong>
    <% commentMap[review.id].forEach(comment => { %>
        <%- include('../partials/comment.ejs', {comment : comment}) %> 
    <% }) %>
    <br>
    <form action="/comments" method="POST"> 
        <input type="text" name="comment">
        <button type="submit" name="review" value=<%=review.id%> >Comment</button>
        <br><br>
    </form>
</div>