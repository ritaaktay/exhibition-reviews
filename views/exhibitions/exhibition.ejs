<!-- context variables are exhibition = exhibition document, 
    location = location document,
    reviews = array of review documents, 
    commentMap = review.ids mapped to arrays of comment documents -->
<body>
    <h2> <%=exhibition.title%> </h2>
    <span> <%=location.location%> </span> <br>
    <br>
    <form action="/reviews" method="POST">
        <lable> Your thoughts: <br>
            <textarea required style="width:60%" name="review" ></textarea>
        </lable> <br>
        <lable> Images <input type="file" class="filepond" name="image" accept="image/*" multiple > </lable> <br>
        <!-- I want this button to display/hide form onclick -->
        <button type="submit" name="exhibition" value="<%=exhibition._id%>"> + </button>
    </form>
    <br>
    <% reviews.forEach(review => { %>
        <%- include('../reviews/_review.ejs', {review: review, commentMap: commentMap}) %>
    <% }) %>
    
</body>

